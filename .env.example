# نظام إدارة الاستثمار في نينوى — متغيّرات البيئة
# انسخ هذا الملف إلى .env.local واملأ القيم. ملفّ .env.local متجاهَل من git ولا يُلتزَم أبداً.

# Supabase — عام بالتصميم (محميّ بـRLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — خادم فقط (لا يصل العميل)
SUPABASE_SERVICE_ROLE_KEY=

# قاعدة البيانات — خادم فقط · Session pooler (منفذ 5432) · للهجرات والاستيراد
DATABASE_URL=

# الذكاء — خادم فقط (Anthropic) · م4. النموذج الافتراضي (يُتجاوَز بإعدادات المستخدم في م5) — ضع اسم نموذج صالح.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# التضمينات — خادم فقط (Voyage AI) · RAG على الطبقة القانونية (م4). البُعد 1024 = voyage-3.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# الخريطة — خادم فقط · يمرّ عبر وسيط في م1 (لا يصل العميل)
MAPTILER_KEY=
