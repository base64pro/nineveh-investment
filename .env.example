# نظام إدارة الاستثمار في نينوى — متغيّرات البيئة
# انسخ هذا الملف إلى .env.local واملأ القيم. ملفّ .env.local متجاهَل من git ولا يُلتزَم أبداً.

# Supabase — عام بالتصميم (محميّ بـRLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — خادم فقط (لا يصل العميل)
SUPABASE_SERVICE_ROLE_KEY=

# قاعدة البيانات — خادم فقط · Session pooler (منفذ 5432) · للهجرات والاستيراد
DATABASE_URL=

# الذكاء — خادم فقط (Anthropic) · م4.
# APP_ANTHROPIC_KEY: مفتاح Anthropic. (اسم مميّز عمداً: بيئة Claude Code تحجز ANTHROPIC_API_KEY وتحقنه فارغاً.)
# ANTHROPIC_MODEL: الافتراضي = أقوى Claude Opus 4.8 · قابل للتغيير من إعدادات التطبيق (م5). مثل claude-opus-4-8.
APP_ANTHROPIC_KEY=
ANTHROPIC_MODEL=

# التضمينات — خادم فقط (Voyage AI) · RAG على الطبقة القانونية (م4). البُعد 1024 = voyage-3.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# الخريطة — خادم فقط · يمرّ عبر وسيط في م1 (لا يصل العميل)
MAPTILER_KEY=

# صور القمر الصناعي البديلة (م9.8) — خادم فقط · تمرّ عبر /api/imagery (المفتاح لا يصل العميل).
# المزوّد الفعّال يُضبَط بـSATELLITE_PROVIDER في src/features/map/lib/map-config.ts.
# Esri: محلّياً يعمل بلا مفتاح (نقطة تقييم)؛ للإنتاج يلزم مفتاح ArcGIS Location Platform. (مجمَّدة 2021 فوق الموصل.)
ESRI_API_KEY=
# Google Map Tiles API (الأوضح/الأحدث) — مفتاح Google Maps Platform مع تفعيل "Map Tiles API" + حساب فوترة.
# يُحقَن خادمياً في /api/imagery/google (مع session token). ⚠ للإنتاج يلزم إظهار شعار Google + إسناد Maxar.
GOOGLE_MAPS_KEY=
# Azure Maps — subscription key من حساب Azure Maps (Gen2). يُحقَن خادمياً في /api/imagery/azure.
AZURE_MAPS_KEY=
# Airbus OneAtlas (تجريبي) — مفتاح الـAPI + قالب بلاطة WMTS لموقعك (الموصل) من حساب التجربة، فيه {z}/{x}/{y}.
AIRBUS_API_KEY=
AIRBUS_WMTS_TEMPLATE=
