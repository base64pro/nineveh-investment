# نظام إدارة الاستثمار في نينوى — متغيّرات البيئة
# انسخ هذا الملف إلى .env.local واملأ القيم. ملفّ .env.local متجاهَل من git ولا يُلتزَم أبداً.

# Supabase — عام بالتصميم (محميّ بـRLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — خادم فقط (لا يصل العميل)
SUPABASE_SERVICE_ROLE_KEY=

# قاعدة البيانات — خادم فقط · Session pooler (منفذ 5432) · للهجرات والاستيراد
DATABASE_URL=

# الذكاء — خادم فقط (Anthropic) · م4.
# APP_ANTHROPIC_KEY: مفتاح Anthropic. (اسم مميّز عمداً: بيئة Claude Code تحجز ANTHROPIC_API_KEY وتحقنه فارغاً.)
# ANTHROPIC_MODEL: الافتراضي = أقوى Claude Opus 4.8 · قابل للتغيير من إعدادات التطبيق (م5). مثل claude-opus-4-8.
APP_ANTHROPIC_KEY=
ANTHROPIC_MODEL=

# التضمينات — خادم فقط (Voyage AI) · RAG على الطبقة القانونية (م4). البُعد 1024 = voyage-3.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# الخريطة — خادم فقط · يمرّ عبر وسيط في م1 (لا يصل العميل)
MAPTILER_KEY=

# صور القمر الصناعي (م9.11) — مزوّدان فقط: maptiler | google. خادم فقط · تمرّ عبر /api/imagery (المفتاح لا يصل العميل).
# المزوّد الفعّال يُضبَط بمتغيّر البيئة التالي (بلا تعديل كود) — القيَم: maptiler|google (الافتراضي maptiler).
# للانتقال إلى Google: اضبط NEXT_PUBLIC_SATELLITE_PROVIDER=google + GOOGLE_MAPS_KEY أدناه (ثمّ أعِد البناء/التشغيل).
NEXT_PUBLIC_SATELLITE_PROVIDER=maptiler
# Google Map Tiles API (الأوضح/الأحدث) — مفتاح Google Maps Platform مع تفعيل "Map Tiles API" + حساب فوترة.
# يُحقَن خادمياً في /api/imagery/google (مع session token + كاش يوم للأداء/التوفير). ⚠ للإنتاج يُنصح بإظهار شعار Google + إسناد Maxar.
GOOGLE_MAPS_KEY=
